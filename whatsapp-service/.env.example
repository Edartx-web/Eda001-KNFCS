# Copy to .env and fill in values
PORT=3001
INTERNAL_KEY=knfc-wa-internal-key
DJANGO_URL=https://knfc-backend.onrender.com
LOG_LEVEL=info
SITE_URL=https://knfcs.com

# Supabase S3 — same values as Django backend
# Sessions saved here so they survive Render restarts (no disk needed)
SUPABASE_S3_URL=https://<ref>.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_REGION=ap-southeast-2
SUPABASE_BUCKET=knfc-media
