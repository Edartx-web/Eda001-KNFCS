# Production environment variables for React build
# Set REACT_APP_API_URL to your production backend URL

# API base URL — leave blank to use hostname-based auto-detection (axiosClient.js)
# Set this explicitly for fully separate frontend/backend deployments:
# REACT_APP_API_URL=https://api.yourproduction.com/api/v1

# WebSocket config
REACT_APP_WS_PORT=443

# Disable source maps in production build (reduces bundle size & hides source)
GENERATE_SOURCEMAP=false
