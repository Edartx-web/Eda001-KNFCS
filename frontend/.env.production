# Production environment — knfcs.com deployment
# Django backend  : api.knfcs.com  (Cloudflare Tunnel → localhost:1000)
# React frontend  : knfcs.com      (Cloudflare Tunnel → localhost:3000)
# WhatsApp service: wa.knfcs.com   (Cloudflare Tunnel → localhost:3001)

# REST API base URL
REACT_APP_API_URL=https://api.knfcs.com/api/v1

# WebSocket host (wss:// — port 443 is implicit with Cloudflare Tunnel)
REACT_APP_WS_HOST=api.knfcs.com

# Disable source maps (reduces bundle size & hides source)
GENERATE_SOURCEMAP=false
