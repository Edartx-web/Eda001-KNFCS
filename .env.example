# ─── Copy this file to .env and fill in your values ──────────────────────────
# Never commit .env to version control

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=knfcs.com,www.knfcs.com,api.knfcs.com

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=knfc_db
DB_USER=knfc_user
DB_PASSWORD=your-database-password
DB_HOST=127.0.0.1
DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ─── 2Factor.in (OTP SMS) ─────────────────────────────────────────────────────
TWO_FACTOR_API_KEY=your-2factor-api-key-here

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=KNFC <noreply@gmail.com>

# ─── WhatsApp Service ─────────────────────────────────────────────────────────
WHATSAPP_SERVICE_URL=http://127.0.0.1:3001
WHATSAPP_INTERNAL_KEY=your-whatsapp-internal-key

# ─── Site ─────────────────────────────────────────────────────────────────────
SITE_URL=https://knfcs.com

# ─── Production ───────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://knfcs.com,https://www.knfcs.com,https://api.knfcs.com
