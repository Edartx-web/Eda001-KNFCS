# ══════════════════════════════════════════════════════════════════
#  KNFC — .gitignore
#  Covers: Django, React (CRA), Node, Python, OS, IDE, deployment
# ══════════════════════════════════════════════════════════════════

# ── Secrets / environment ─────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyw
*.pyz
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/
pip-wheel-metadata/
MANIFEST

# ── Django runtime ────────────────────────────────────────────────
*.log
*.log.*
logs/
!logs/.gitkeep
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
media/
!staticfiles/.gitkeep
!media/.gitkeep

# ── Virtual environments ──────────────────────────────────────────
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# ── Celery ────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid

# ── Node / React ──────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── WhatsApp service ──────────────────────────────────────────────
whatsapp-service/node_modules/
whatsapp-service/sessions/
whatsapp-service/auth_info_*/
whatsapp-service/*.log

# ── Large binary assets — tracked via Git LFS (see .gitattributes) ──
# frontend/src/components/videoclips/*.mp4  ← now handled by LFS
frontend/src/components/videoclips/*.webm
frontend/public/assets/video/

# ── Source / working data files (already imported into DB) ────────
MenuImage/
KNFCMENU*.xlsx
KNFCMENULIST.xlsx
MENULIST.txt

# ── IDE / Editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.orig
*.sublime-project
*.sublime-workspace

# ── Operating system ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Testing / Coverage ────────────────────────────────────────────
.coverage
coverage.xml
.pytest_cache/
htmlcov/
.tox/
nosetests.xml

# ── Type checking ─────────────────────────────────────────────────
.mypy_cache/
.dmypy.json

# ── Working / scratch files ───────────────────────────────────────
Prompt.txt
notes.txt
issues_list.txt
TODO.txt
DEPLOYMENT_INFO.txt
env.txt
KNFC_PROJECT_MANUAL.txt
scratch/
tmp/

# ── Claude Code / AI tooling ──────────────────────────────────────
.claude/

# ── Deployment artefacts ──────────────────────────────────────────
*.pid
*.seed
*.pid.lock

# ── Server logs ───────────────────────────────────────────────────
daphne_startup.log
gunicorn.log
gunicorn.pid
access.log
error.log

# ── WhatsApp service secrets ──────────────────────────────────────
whatsapp-service/.env
whatsapp-service/.env.local

# ── Temp extraction dirs ──────────────────────────────────────────
favicon_io_extracted/
*_extracted/
DEPLOYMENT.md
.vercel
